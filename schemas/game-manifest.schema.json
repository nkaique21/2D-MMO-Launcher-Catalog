{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/nkaique21/2D-MMO-Launcher-Catalog/main/schemas/game-manifest.schema.json",
  "title": "2D MMO Launcher Game Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "description", "assets", "installation", "launch", "update"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,79}$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["banner", "icon"],
      "properties": {
        "banner": { "type": "string", "minLength": 1 },
        "icon": { "type": "string", "minLength": 1 }
      }
    },
    "installation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["methods"],
      "properties": {
        "methods": {
          "type": "array",
          "items": { "$ref": "#/$defs/installMethod" }
        }
      }
    },
    "launch": { "$ref": "#/$defs/launch" },
    "update": { "$ref": "#/$defs/update" },
    "verification": { "$ref": "#/$defs/verification" }
  },
  "$defs": {
    "stringMap": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "installMethod": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "runner": { "type": "string" },
        "compatPrefix": { "type": "string" },
        "installPath": { "type": "string" },
        "launchAfterInstall": { "type": "boolean" },
        "format": { "type": "string" },
        "stripTopLevelDir": { "type": "boolean" },
        "headers": { "$ref": "#/$defs/stringMap" }
      }
    },
    "launch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runner", "executable", "args"],
      "properties": {
        "runner": { "type": "string", "minLength": 1 },
        "executable": { "type": ["string", "null"] },
        "args": { "type": "array", "items": { "type": "string" } },
        "env": { "$ref": "#/$defs/stringMap" },
        "unsetEnv": { "type": "array", "items": { "type": "string" } },
        "battlEye": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["executable"],
          "properties": {
            "enabled": { "type": "boolean" },
            "executable": { "type": "string", "minLength": 1 },
            "args": { "type": "array", "items": { "type": "string" } },
            "installArgs": { "type": "array", "items": { "type": "string" } },
            "installBeforeLaunch": { "type": "boolean" },
            "launchMode": { "type": "string" },
            "pathBase": { "type": "string" },
            "workingDir": { "type": "string" },
            "workingDirBase": { "type": "string" },
            "required": { "type": "boolean" }
          }
        }
      }
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy"],
      "properties": {
        "strategy": { "type": "string", "minLength": 1 },
        "runner": { "type": "string" },
        "compatPrefix": { "type": "string" },
        "executable": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "pathBase": { "type": "string" },
        "workingDir": { "type": "string" },
        "workingDirBase": { "type": "string" },
        "env": { "$ref": "#/$defs/stringMap" },
        "unsetEnv": { "type": "array", "items": { "type": "string" } },
        "manifestUrl": { "type": "string", "format": "uri" },
        "manifestFormat": { "type": "string" },
        "targetDir": { "type": "string" },
        "targetDirBase": { "type": "string" },
        "maxConcurrentDownloads": { "type": "integer", "minimum": 1, "maximum": 16 }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requiredFiles": { "type": "array", "items": { "type": "string" } },
        "checksums": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "algorithm", "value"],
            "properties": {
              "path": { "type": "string" },
              "algorithm": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
